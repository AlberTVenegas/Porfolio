---
import "/src/styles/global.css";
import "../styles/global.css";
import Header from "../components/Header.astro";
import Resume from "../components/Resume.astro";
import Experience from "../components/Experience.astro";
import Projects from "../components/Projects.astro";
import Skills from "../components/Skills.astro";
import Footer from "../components/Footer.astro";
import SobreMi from "../components/SobreMi.astro";
import Courses from "../components/Courses.astro";

interface Props {
  title?: string;
}
const { title = "Albert Venegas - Portfolio" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link
      href="https://cdn.jsdelivr.net/npm/flowbite@3.1.2/dist/flowbite.min.css"
      rel="stylesheet"
    />
    <title>{title}</title>
    <meta
      name="description"
      content="Portfolio de Albert Venegas, Analista de Datos"
    />
    <link rel="icon" type="image/svg+xml" href="/icon.webp" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@100..900&family=Onest:wght@100..900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- Fondo animado -->
    <canvas id="bg-canvas" class="fixed inset-0 z-[-2] w-full h-full"></canvas>

    <div class="absolute top-0 z-[-1] w-full">
      <header class="fixed top-0 left-1/2 -translate-x-1/2 w-full max-w-2xl px-4 z-50">
        <><Header id="top" /> </>
      </header>
      <main class="w-full max-w-4xl mx-auto mt-28 md:mt-36 px-4">
        <slot> <section><Resume /></section></slot>
        <section class="border-2 border-transparent" id="experiencia">
          <div class="flex items-center gap-5 mb-7 mt-36">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="#8E51FF"
              class="size-6 text-gray-900 dark:text-white"
              ><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
                d="M14 2a3 3 0 0 1 3 3v1h2a3 3 0 0 1 3 3v9a3 3 0 0 1 -3 3h-14a3 3 0 0 1 -3 -3v-9a3 3 0 0 1 3 -3h2v-1a3 3 0 0 1 3 -3zm0 2h-4a1 1 0 0 0 -1 1v1h6v-1a1 1 0 0 0 -1 -1"
              ></path></svg
            >

            <h2 class="text-3xl font-bold text-gray-900 dark:text-white">
              Experiencia Laboral
            </h2>
          </div>

          <Experience />
        </section>
        <section
          class="border-2 border-transparent flex items-center"
          id="proyectos"
        >
          <Projects />
        </section>
        <section class="border-2 border-transparent" id="tecnologías">
          <Skills />
        </section>
        <section class="border-2 border-transparent" id="cursos">
          <Courses />
        </section>
        <section class="border-2 border-transparent" id="sobremi">
          <SobreMi />
        </section>
      </main>
      <footer class="rounded-lg shadow-sm m-4 dark:bg-[#0A0A0A]">
        <Footer />
      </footer>
    </div>
  </body>

  <style is:global>
    :root {
      color-scheme: light dark;
      scroll-behavior: smooth;
    }
    body {
      font-family: Onest, sans-serif;
      display: flex;
      justify-content: center;
      align-items: center;
      flex-direction: column;
      background-color: #0a0a0a;
    }
    @media (prefers-reduced-motion: reduce) {
      html { scroll-behavior: auto; }
      #bg-canvas { display: none; }
    }
  </style>

  <script is:inline>
    (function () {
      const canvas = document.getElementById("bg-canvas");
      const ctx    = canvas.getContext("2d");

      function resize() {
        canvas.width  = window.innerWidth;
        canvas.height = window.innerHeight;
      }
      resize();
      window.addEventListener("resize", resize);

      // ── Orbes flotantes ──────────────────────────────────────────
      const ORBS = [
        { x: 0.25, y: -0.05, r: 0.55, color: "rgba(120,80,220,0.13)", speedX: 0.00012, speedY: 0.00008 },
        { x: 0.75, y: 0.35,  r: 0.40, color: "rgba(90,50,180,0.10)",  speedX: -0.0001, speedY: 0.00006 },
        { x: 0.50, y: 0.80,  r: 0.35, color: "rgba(150,80,255,0.08)", speedX: 0.00007, speedY: -0.0001 },
      ];

      // ── Partículas ────────────────────────────────────────────────
      const PARTICLE_COUNT = 70;
      const particles = Array.from({ length: PARTICLE_COUNT }, () => makeParticle(true));

      function makeParticle(randomY) {
        return {
          x:       Math.random() * window.innerWidth,
          y:       randomY ? Math.random() * window.innerHeight : window.innerHeight + 4,
          size:    Math.random() * 1.4 + 0.3,
          speedY:  -(Math.random() * 0.25 + 0.08),
          speedX:  (Math.random() - 0.5) * 0.1,
          alpha:   Math.random() * 0.5 + 0.15,
          twinkle: Math.random() * Math.PI * 2,
          twinkleSpeed: Math.random() * 0.02 + 0.001,
        };
      }

      let t = 0;

      function draw() {
        const W = canvas.width;
        const H = canvas.height;
        ctx.clearRect(0, 0, W, H);

        // Fondo base
        ctx.fillStyle = "#0a0a0a";
        ctx.fillRect(0, 0, W, H);

        // Orbes con movimiento sinusoidal


        // Partículas
        for (const p of particles) {
          p.twinkle += p.twinkleSpeed;
          const alpha = p.alpha * (0.7 + 0.3 * Math.sin(p.twinkle));

          ctx.beginPath();
          ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(180,150,255,${alpha})`;
          ctx.fill();

          p.y += p.speedY;
          p.x += p.speedX;

          if (p.y < -4) Object.assign(p, makeParticle(false));
        }

        t += 16;
        requestAnimationFrame(draw);
      }

      draw();
    })();
  </script>
</html>
