---
const COURSES = [
  {
    img: "/imgCursos/Python.jpg",
    title: "Python: De Principiante a Avanzado",
    platform: "Udemy",
    date: "2025",
  },
  {
    img: "/imgCursos/Excel.jpg",
    title: "Microsoft Excel: De cero a analista de datos en Power BI",
    platform: "Udemy",
    date: "2025",
  },
  {
    img: "/imgCursos/Dax.jpg",
    title: "Especialización en lenguaje DAX para análisis de negocios.",
    platform: "Udemy",
    date: "2026",
  },
  {
    img: "/imgCursos/Excel_.jpg",
    title: "Universidad Excel - Básico, Intermedio y Avanzado!",
    platform: "Udemy",
    date: "2025",
  },

  // Agrega más cursos aquí siguiendo la misma estructura
];
---

<!-- Modal lightbox -->
<div
  id="course-modal"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-black/80 backdrop-blur-sm p-4"
  role="dialog"
  aria-modal="true"
>
  <button
    id="modal-close"
    class="absolute top-4 right-4 text-gray-400 hover:text-white transition-colors duration-200 bg-neutral-900/80 rounded-full p-2"
    aria-label="Cerrar"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="size-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>

  <div id="modal-content" class="max-w-5xl w-full max-h-[90vh] flex flex-col gap-3">
    <img
      id="modal-img"
      src=""
      alt=""
      class="w-full max-h-[80vh] object-contain rounded-xl shadow-2xl shadow-violet-900/30 border border-violet-800/30"
    />
    <div class="text-center">
      <p id="modal-platform" class="text-violet-400 text-xs font-mono tracking-widest"></p>
      <h3 id="modal-title" class="text-white font-semibold text-lg mt-1"></h3>
    </div>
  </div>
</div>

<style>
  #course-modal {
    animation: none;
  }
  #course-modal.modal-enter {
    animation: modalFadeIn 0.25s ease forwards;
  }
  #course-modal.modal-leave {
    animation: modalFadeOut 0.2s ease forwards;
  }
  #modal-content {
    animation: none;
  }
  #course-modal.modal-enter #modal-content {
    animation: contentPop 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  @keyframes modalFadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  @keyframes modalFadeOut {
    from { opacity: 1; }
    to   { opacity: 0; }
  }
  @keyframes contentPop {
    from { opacity: 0; transform: scale(0.88) translateY(12px); }
    to   { opacity: 1; transform: scale(1)    translateY(0);    }
  }
</style>

<!-- Grid de cursos -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
  {COURSES.map((course) => (
    <article
      class="course-card bg-neutral-900 border border-violet-800/40 rounded-2xl overflow-hidden flex flex-col group hover:border-violet-600/60 transition-colors duration-300 cursor-pointer"
      data-img={course.img}
      data-title={course.title}
      data-platform={course.platform}
    >
      <div class="bg-neutral-950/50 overflow-hidden relative">
        <img
          src={course.img}
          alt={course.title}
          class="w-full h-48 object-cover group-hover:scale-105 transition-transform duration-500"
        />
        <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300 bg-black/40">
          <svg xmlns="http://www.w3.org/2000/svg" class="size-10 text-white drop-shadow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="6" />
            <line x1="11" y1="8.5" x2="11" y2="13.5" />
            <line x1="8.5" y1="11" x2="13.5" y2="11" />
            <line x1="21" y1="21" x2="16.2" y2="16.2" />
          </svg>
        </div>
      </div>
      <div class="flex flex-col gap-2 p-4 flex-1">
        <span class="text-violet-600/60 text-xs font-mono tracking-widest">{course.platform}</span>
        <h3 class="text-base font-semibold text-white leading-snug">{course.title}</h3>
        <p class="text-gray-500 text-xs mt-auto">{course.date}</p>
      </div>
    </article>
  ))}
</div>

<script is:inline>
  const modal      = document.getElementById("course-modal");
  const modalImg   = document.getElementById("modal-img");
  const modalTitle = document.getElementById("modal-title");
  const modalPlat  = document.getElementById("modal-platform");
  const closeBtn   = document.getElementById("modal-close");

  function openModal(img, title, platform) {
    modalImg.src             = img;
    modalImg.alt             = title;
    modalTitle.textContent   = title;
    modalPlat.textContent    = platform;
    modal.classList.remove("hidden", "modal-leave");
    modal.classList.add("flex", "modal-enter");
    document.body.style.overflow = "hidden";
  }

  function closeModal() {
    modal.classList.remove("modal-enter");
    modal.classList.add("modal-leave");
    modal.addEventListener("animationend", () => {
      modal.classList.add("hidden");
      modal.classList.remove("flex", "modal-leave");
      document.body.style.overflow = "";
    }, { once: true });
  }

  document.querySelectorAll(".course-card").forEach((card) => {
    card.addEventListener("click", () => {
      openModal(card.dataset.img, card.dataset.title, card.dataset.platform);
    });
  });

  closeBtn.addEventListener("click", closeModal);

  modal.addEventListener("click", (e) => {
    if (e.target === modal) closeModal();
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeModal();
  });
</script>
