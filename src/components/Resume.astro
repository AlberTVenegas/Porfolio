---
import Icons from "./Icons.astro";
---

<div class="w-full py-10">
  <div class="flex flex-col-reverse sm:flex-row items-center sm:items-start gap-10">

    <!-- Texto -->
    <section class="flex-1 flex flex-col gap-5">

      <!-- Badge disponibilidad -->
      <div class="flex">
        <span class="inline-flex items-center gap-2 bg-violet-950/60 border border-violet-700/50 text-violet-300 text-xs font-medium px-3 py-1.5 rounded-full">
          <span class="w-2 h-2 rounded-full bg-violet-400 animate-pulse"></span>
          Disponible para trabajar
        </span>
      </div>

      <!-- Nombre -->
      <div class="flex flex-col gap-1">
        <p class="text-gray-500 text-sm tracking-widest uppercase">Hola, soy</p>
        <h1 class="text-4xl sm:text-5xl font-bold text-white leading-tight">
          Albert Venegas
        </h1>
        <h2 class="text-xl sm:text-2xl font-semibold text-violet-400 mt-1">
          Analista de Datos
        </h2>
      </div>

      <!-- Descripción -->
      <p class="text-gray-400 text-base leading-relaxed max-w-lg">
        Egresado de Ingeniería en Informática 🇨🇱, apasionado por convertir datos
        en decisiones mediante <span class="text-violet-300 font-medium">Python</span>,
        <span class="text-violet-300 font-medium">SQL</span> y
        <span class="text-violet-300 font-medium">Power BI</span>.
        Experiencia en limpieza, análisis y visualización de datos, dashboards
        interactivos y procesos ETL eficientes.
      </p>

      <!-- Íconos sociales -->
      <Icons />

    </section>

    <!-- Foto -->
    <div class="shrink-0 relative">
      <div class="w-36 h-36 sm:w-52 sm:h-52 rounded-2xl overflow-hidden ring-2 ring-violet-700/60 shadow-xl shadow-violet-950/50">
        <img src="./img.webp" alt="Albert Venegas" class="w-full h-full object-cover" />
      </div>
      <!-- Decoración esquina -->
      <div class="absolute -bottom-2 -right-2 w-10 h-10 rounded-xl bg-violet-900/60 border border-violet-700/40 flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="#8E51FF" class="size-5">
          <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
          <path d="M9.183 6.117a6 6 0 1 0 4.511 3.986"/>
          <path d="M14 10l-3.5 3.5"/>
          <path d="M12 6l0 -3"/>
          <path d="M6 12l-3 0"/>
          <path d="M7.5 7.5l-2.5 -2.5"/>
        </svg>
      </div>
    </div>

  </div>
</div>
